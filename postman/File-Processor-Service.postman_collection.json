  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Verificar configuración de la petición",
          "if (pm.request.body && pm.request.body.mode === 'formdata') {",
          "    const fileKey = pm.request.body.formdata.find(p => p.key === 'file');",
          "    if (!fileKey || !fileKey.src) {",
          "        console.log('⚠️ ADVERTENCIA: No se ha seleccionado archivo.');",
          "        console.log('👉 Ve a Body > form-data, haz clic en el campo file y selecciona un archivo.');",
          "    } else {",
          "        console.log('✅ Archivo seleccionado: ' + fileKey.src);",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "// Validar respuesta",
          "if (pm.response.code === 200) {",
          "    const jsonData = pm.response.json();",
          "    pm.test('Respuesta exitosa', function () {",
          "        pm.expect(jsonData.success).to.be.true;",
          "        pm.expect(jsonData.status).to.eql('SUCCESS');",
          "    });",
          "} else if (pm.response.code === 500) {",
          "    const jsonData = pm.response.json();",
          "    if (jsonData.message && jsonData.message.includes('No file provided')) {",
          "        pm.test('⚠️ No seleccionaste archivo', function () {",
          "            pm.expect.fail('Ve a Body > form-data y selecciona un archivo en el campo file');",
          "        });",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
